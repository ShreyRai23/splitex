# Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development

# Database — MySQL connection string for Prisma
DATABASE_URL="mysql://root:password@localhost:3306/spiltex"

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Static Exchange Rate (USD → INR) — locked at ingestion time per spec
USD_TO_INR_RATE=84.0
